    "test:architecture": "node --test tests/taskloop-architecture.test.mjs",
    "test:installer": "node --test tests/installer.test.mjs",
    "test:skills": "node --test tests/skills.test.mjs",
    "test:windows": "node --test tests/windows.test.mjs",
    "install:user": "node install.mjs",
    "install:user:dry-run": "node install.mjs --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hex1n/taskloop.git"
  },
